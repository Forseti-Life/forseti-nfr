/**
 * Create nfr_cancer_diagnoses table and add health condition columns.
 */
function nfr_update_9012() {
  $schema = \Drupal::database()->schema();
  $database = \Drupal::database();
  
  // Create nfr_cancer_diagnoses table
  if (!$schema->tableExists('nfr_cancer_diagnoses')) {
    $schema->createTable('nfr_cancer_diagnoses', [
      'fields' => [
        'id' => [
          'type' => 'serial',
          'not null' => TRUE,
        ],
        'uid' => [
          'type' => 'int',
          'not null' => TRUE,
          'description' => 'User ID',
        ],
        'cancer_type' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => FALSE,
        ],
        'year_diagnosed' => [
          'type' => 'int',
          'not null' => FALSE,
        ],
        'created' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
        ],
        'updated' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'uid' => ['uid'],
      ],
    ]);
  }
  
  // Add health condition columns
  $conditions = ['heart_disease', 'copd', 'asthma', 'diabetes'];
  foreach ($conditions as $condition) {
    $col_name = 'health_' . $condition;
    if (!$schema->fieldExists('nfr_questionnaire', $col_name)) {
      $schema->addField('nfr_questionnaire', $col_name, [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 0,
      ]);
    }
  }
  
  // Migrate data from cancer_details JSON to new structures
  if ($schema->fieldExists('nfr_questionnaire', 'cancer_details')) {
    $results = $database->select('nfr_questionnaire', 'q')
      ->fields('q', ['uid', 'cancer_details'])
      ->condition('cancer_details', '', '<>')
      ->isNotNull('cancer_details')
      ->execute();
    
    $time = \Drupal::time()->getRequestTime();
    
    foreach ($results as $row) {
      $data = json_decode($row->cancer_details, TRUE);
      if (!empty($data)) {
        // Migrate cancer diagnoses to new table
        if (!empty($data['cancers']) && is_array($data['cancers'])) {
          foreach ($data['cancers'] as $cancer) {
            if (!empty($cancer['type'])) {
              $database->insert('nfr_cancer_diagnoses')
                ->fields([
                  'uid' => $row->uid,
                  'cancer_type' => $cancer['type'],
                  'year_diagnosed' => !empty($cancer['year_diagnosed']) ? (int) $cancer['year_diagnosed'] : NULL,
                  'created' => $time,
                  'updated' => $time,
                ])
                ->execute();
            }
          }
        }
        
        // Migrate other conditions to boolean columns
        if (!empty($data['other_conditions']) && is_array($data['other_conditions'])) {
          $update_fields = [];
          foreach ($conditions as $condition) {
            if (in_array($condition, $data['other_conditions'])) {
              $update_fields['health_' . $condition] = 1;
            }
          }
          
          if (!empty($update_fields)) {
            $database->update('nfr_questionnaire')
              ->fields($update_fields)
              ->condition('uid', $row->uid)
              ->execute();
          }
        }
      }
    }
    
    // Drop the old JSON column
    $schema->dropField('nfr_questionnaire', 'cancer_details');
  }
  
  return t('Created nfr_cancer_diagnoses table and added health condition columns.');
}

/**
 * Create nfr_section_completion table for individual section tracking.
 */
function nfr_update_9013() {
  $schema = \Drupal::database()->schema();
  
  // Create the section completion tracking table
  if (!$schema->tableExists('nfr_section_completion')) {
    $table = [
      'description' => 'Tracks individual section completion status for questionnaire.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'not null' => TRUE,
          'description' => 'Primary key',
        ],
        'uid' => [
          'type' => 'int',
          'not null' => TRUE,
          'description' => 'User ID',
        ],
        'section_number' => [
          'type' => 'int',
          'size' => 'tiny',
          'not null' => TRUE,
          'description' => 'Section number (1-9)',
        ],
        'completed' => [
          'type' => 'int',
          'size' => 'tiny',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Whether section is completed (0 or 1)',
        ],
        'completed_at' => [
          'type' => 'int',
          'not null' => FALSE,
          'description' => 'Timestamp when section was completed',
        ],
        'updated' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Timestamp when record was last updated',
        ],
      ],
      'primary key' => ['id'],
      'unique keys' => [
        'uid_section' => ['uid', 'section_number'],
      ],
      'indexes' => [
        'uid' => ['uid'],
        'section_number' => ['section_number'],
      ],
    ];
    
    $schema->createTable('nfr_section_completion', $table);
  }
  
  // Migrate existing progress from last_section_completed
  $database = \Drupal::database();
  $questionnaires = $database->select('nfr_questionnaire', 'q')
    ->fields('q', ['uid', 'last_section_completed'])
    ->execute();
  
  foreach ($questionnaires as $row) {
    if ($row->last_section_completed > 0) {
      // Mark all sections up to last_section_completed as complete
      for ($section = 1; $section <= $row->last_section_completed; $section++) {
        $database->merge('nfr_section_completion')
          ->keys([
            'uid' => $row->uid,
            'section_number' => $section,
          ])
          ->fields([
            'completed' => 1,
            'completed_at' => time(),
            'updated' => time(),
          ])
          ->execute();
      }
    }
  }
  
  return t('Created nfr_section_completion table and migrated existing progress.');
}

