      'not null' => FALSE,
    ],
    'sleep_disorders' => [
      'description' => 'Sleep disorders (JSON array)',
      'type' => 'text',
      'size' => 'normal',
      'not null' => FALSE,
    ],
  ];
  
  $added = 0;
  foreach ($sleep_columns as $column_name => $spec) {
    if (!$schema->fieldExists($table, $column_name)) {
      $schema->addField($table, $column_name, $spec);
      $added++;
    }
  }
  
  return t('Added @count sleep tracking columns to nfr_questionnaire table.', ['@count' => $added]);
}
