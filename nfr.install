/**
 * Remove unused columns from nfr_job_titles table.
 */
function nfr_update_9006() {
  $schema = \Drupal::database()->schema();
  
  // Drop start_date and end_date - job dates aren't tracked, only department dates
  if ($schema->fieldExists('nfr_job_titles', 'start_date')) {
    $schema->dropField('nfr_job_titles', 'start_date');
  }
  if ($schema->fieldExists('nfr_job_titles', 'end_date')) {
    $schema->dropField('nfr_job_titles', 'end_date');
  }
  
  // Drop incident_types JSON - data properly stored in nfr_incident_frequency table
  if ($schema->fieldExists('nfr_job_titles', 'incident_types')) {
    $schema->dropField('nfr_job_titles', 'incident_types');
  }
  
  return t('Removed unused columns from nfr_job_titles table.');
}

