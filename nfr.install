<?php

/**
 * @file
 * Install, update and uninstall functions for the NFR module.
 */

/**
 * Implements hook_install().
 */
function nfr_install() {
  // Create all database tables (orphaned from Drupal schema system)
  _nfr_create_tables();
  
  // Assign permissions to roles
  _nfr_assign_role_permissions();
  
  // Create validation test users
  _nfr_create_validation_users();
  
  \Drupal::messenger()->addStatus(t('NFR module installed successfully. All data tables created and will persist across uninstall/reinstall.'));
}

/**
 * Create all NFR database tables.
 * 
 * Tables are created directly via schema API instead of hook_schema()
 * so they are "orphaned" from Drupal's schema management system.
 * This prevents automatic deletion during module uninstall.
 * 
 * Note: Tables are actually created by update hooks (9007, 9008, 9009, 9010, 9011, 9012, 9013).
 * This function just verifies they exist and logs status.
 */
function _nfr_create_tables() {
  $schema = \Drupal::database()->schema();
  
  $expected_tables = [
    'nfr_user_profile',
    'nfr_work_history',
    'nfr_job_titles',
    'nfr_incident_frequency',
    'nfr_major_incidents',
    'nfr_other_employment',
    'nfr_cancer_diagnoses',
    'nfr_consent',
    'nfr_questionnaire',
    'nfr_section_completion',
    'nfr_follow_up_surveys',
  ];
  
  $existing = 0;
  $missing = [];
  
  foreach ($expected_tables as $table) {
    if ($schema->tableExists($table)) {
      $existing++;
    } else {
      $missing[] = $table;
    }
  }
  
  if (!empty($missing)) {
    \Drupal::logger('nfr')->warning('Missing tables during install: @tables. Run drush updb to create them via update hooks.', [
      '@tables' => implode(', ', $missing),
    ]);
  }
  
  \Drupal::logger('nfr')->info('NFR install: @existing of @total tables exist.', [
    '@existing' => $existing,
    '@total' => count($expected_tables),
  ]);
}

/**
 * Helper function to create remaining NFR tables.
 * @deprecated - Tables are created by update hooks, not during install
 */
function _nfr_create_remaining_tables($schema) {
  // Deprecated - tables created by update hooks
}

/**
 * Assign permissions to NFR roles.
 */
function _nfr_assign_role_permissions() {
  $role_permissions = [
    'firefighter' => [
      'access nfr dashboard',
      'view firefighter records',
      'view cancer data',
    ],
    'fire_dept_admin' => [
      'access nfr dashboard',
      'view firefighter records',
      'view cancer data',
    ],
    'nfr_researcher' => [
      'access nfr dashboard',
      'view firefighter records',
      'view cancer data',
      'view nfr reports',
      'export nfr data',
    ],
    'nfr_administrator' => [
      'administer nfr',
      'access nfr dashboard',
      'manage firefighters',
      'view firefighter records',
      'view cancer data',
      'manage cancer data',
      'export nfr data',
      'view nfr reports',
      'manage state registry linkages',
    ],
  ];
  
  foreach ($role_permissions as $role_id => $permissions) {
    $role = \Drupal\user\Entity\Role::load($role_id);
    if ($role) {
      foreach ($permissions as $permission) {
        $role->grantPermission($permission);
      }
      $role->save();
    }
  }
}

/**
 * Create validation test users with specific UIDs.
 */
/**
 * Create or update validation test users.
 * 
 * Following Drupal best practices:
 * - Checks for existing users by username
 * - Let Drupal assign UIDs automatically
 * - Updates existing users instead of overwriting
 * - Uses proper entity API
 */
function _nfr_create_validation_users() {
  $validation_users = [
    ['username' => 'firefighter_test_active', 'role' => 'firefighter', 'first' => 'John', 'last' => 'Smith'],
    ['username' => 'firefighter_test_retired', 'role' => 'firefighter', 'first' => 'Jane', 'last' => 'Doe'],
    ['username' => 'nfr_administrator_test', 'role' => 'nfr_administrator', 'first' => 'Admin', 'last' => 'User'],
    ['username' => 'nfr_researcher_test', 'role' => 'nfr_researcher', 'first' => 'Research', 'last' => 'Analyst'],
    ['username' => 'fire_department_admin_test', 'role' => 'fire_dept_admin', 'first' => 'Fire', 'last' => 'Chief'],
  ];
  
  foreach ($validation_users as $user_data) {
    // Check if user already exists by username (proper Drupal practice)
    $existing_by_name = \Drupal::entityTypeManager()
      ->getStorage('user')
      ->loadByProperties(['name' => $user_data['username']]);
    
    if (!empty($existing_by_name)) {
      $user = reset($existing_by_name);
      // Update role if needed
      if (!$user->hasRole($user_data['role'])) {
        $user->addRole($user_data['role']);
        $user->save();
        \Drupal::logger('nfr')->info('Updated user @username (UID: @uid) to add role: @role', [
          '@username' => $user_data['username'],
          '@uid' => $user->id(),
          '@role' => $user_data['role'],
        ]);
      }
      continue;
    }
    
    try {
      // Create user using Drupal entity system (let Drupal assign UID)
      $user = \Drupal\user\Entity\User::create([
        'name' => $user_data['username'],
        'mail' => $user_data['username'] . '@stlouisintegration.com',
        'pass' => 'TestPassword123!',
        'status' => 1,
        'field_first_name' => $user_data['first'],
        'field_last_name' => $user_data['last'],
        'roles' => [$user_data['role']], // Add role during creation
      ]);
      
      $user->save();
      
      // Log the created user
      \Drupal::logger('nfr')->info('Created validation user @username (UID: @uid) with role: @role', [
        '@username' => $user_data['username'],
        '@uid' => $user->id(),
        '@role' => $user_data['role'],
      ]);
      
    } catch (\Exception $e) {
      \Drupal::logger('nfr')->error('Failed to create validation user @username: @message', [
        '@username' => $user_data['username'],
        '@message' => $e->getMessage(),
      ]);
    }
  }
}

/**
 * Implements hook_uninstall().
 */
/**
 * Implements hook_uninstall().
 * 
 * IMPORTANT: We explicitly preserve all data tables during uninstall.
 * By default, Drupal drops all tables defined in hook_schema() when uninstalling.
 * We prevent this by NOT calling dropTable() and by preserving table data.
 * 
 * This allows reinstalling the module without losing any collected data,
 * consent records, or user information.
 */
function nfr_uninstall() {
  // Get the schema
  $schema = \Drupal::database()->schema();
  
  // List of tables to preserve (do NOT drop)
  $preserve_tables = [
    'nfr_user_profile',
    'nfr_work_history',
    'nfr_job_titles',
    'nfr_incident_frequency',
    'nfr_major_incidents',
    'nfr_other_employment',
    'nfr_cancer_diagnoses',
    'nfr_consent',
    'nfr_questionnaire',
    'nfr_section_completion',
    'nfr_follow_up_surveys',
  ];
  
  // Verify tables exist and will be preserved
  $preserved_count = 0;
  foreach ($preserve_tables as $table) {
    if ($schema->tableExists($table)) {
      $preserved_count++;
    }
  }
  
  \Drupal::messenger()->addStatus(t('NFR module uninstalled. @count data tables have been preserved and will not be deleted.', ['@count' => $preserved_count]));
  
  // Note: We do NOT call $schema->dropTable() for any tables
  // This prevents data loss during module reinstall/updates
}

/**
 * Ensure baseline legacy tables exist for early update hooks.
 */
function _nfr_ensure_update_base_tables() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('nfr_questionnaire')) {
    $schema->createTable('nfr_questionnaire', [
      'description' => 'Legacy questionnaire table used by incremental NFR update hooks.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'not null' => TRUE,
        ],
        'uid' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Drupal user ID',
        ],
        'created' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
        ],
        'updated' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
        ],
      ],
      'primary key' => ['id'],
      'unique keys' => [
        'uid' => ['uid'],
      ],
      'indexes' => [
        'created' => ['created'],
      ],
    ]);
  }

  if (!$schema->tableExists('nfr_job_titles')) {
    $schema->createTable('nfr_job_titles', [
      'description' => 'Legacy normalized job titles table used by NFR update hooks.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'not null' => TRUE,
        ],
        'uid' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Drupal user ID',
        ],
        'created' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'uid' => ['uid'],
      ],
    ]);
  }

  if (!$schema->tableExists('nfr_incident_frequency')) {
    $schema->createTable('nfr_incident_frequency', [
      'description' => 'Legacy incident frequency table used by NFR update hooks.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'not null' => TRUE,
        ],
        'uid' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Drupal user ID',
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'uid' => ['uid'],
      ],
    ]);
  }
}

/**
 * Add missing timestamp columns to normalized work history tables.
 */
function nfr_update_9003() {
  _nfr_ensure_update_base_tables();
  $schema = \Drupal::database()->schema();
  
  // Add created and updated to nfr_incident_frequency
  if (!$schema->fieldExists('nfr_incident_frequency', 'created')) {
    $schema->addField('nfr_incident_frequency', 'created', [
      'type' => 'int',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Timestamp when record was created',
    ]);
  }
  
  if (!$schema->fieldExists('nfr_incident_frequency', 'updated')) {
    $schema->addField('nfr_incident_frequency', 'updated', [
      'type' => 'int',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Timestamp when record was last updated',
    ]);
  }
  
  // Add updated to nfr_job_titles (created already exists)
  if (!$schema->fieldExists('nfr_job_titles', 'updated')) {
    $schema->addField('nfr_job_titles', 'updated', [
      'type' => 'int',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Timestamp when record was last updated',
    ]);
  }
  
  return t('Added timestamp columns to work history tables.');
}

/**
 * Remove generic data JSON column now that we use normalized tables and specific JSON columns.
 */
function nfr_update_9004() {
  $schema = \Drupal::database()->schema();
  
  // Drop the generic 'data' column from nfr_questionnaire
  if ($schema->fieldExists('nfr_questionnaire', 'data')) {
    $schema->dropField('nfr_questionnaire', 'data');
  }
  
  return t('Removed generic data JSON column from nfr_questionnaire table.');
}

