/**
 * Add direct decontamination columns and migrate from JSON.
 */
function nfr_update_9011() {
  $schema = \Drupal::database()->schema();
  $database = \Drupal::database();
  
  $decon_fields = [
    'washed_hands_face' => 'varchar',
    'changed_gear_at_scene' => 'varchar',
    'showered_at_station' => 'varchar',
    'laundered_gear' => 'varchar',
    'used_wet_wipes' => 'varchar',
    'department_had_sops' => 'varchar',
  ];
  
  // Add decontamination practice columns
  foreach ($decon_fields as $field => $type) {
    $col_name = 'decon_' . $field;
    if (!$schema->fieldExists('nfr_questionnaire', $col_name)) {
      $spec = [
        'type' => $type,
        'not null' => FALSE,
      ];
      if ($type === 'varchar') {
        $spec['length'] = ($field === 'department_had_sops') ? 10 : 20;
      }
      $schema->addField('nfr_questionnaire', $col_name, $spec);
    }
  }
  
  // Add sops_year_implemented column
  if (!$schema->fieldExists('nfr_questionnaire', 'decon_sops_year_implemented')) {
    $schema->addField('nfr_questionnaire', 'decon_sops_year_implemented', [
      'type' => 'int',
      'not null' => FALSE,
    ]);
  }
  
  // Migrate data from decon_practices JSON to new columns
  if ($schema->fieldExists('nfr_questionnaire', 'decon_practices')) {
    $results = $database->select('nfr_questionnaire', 'q')
      ->fields('q', ['uid', 'decon_practices'])
      ->condition('decon_practices', '', '<>')
      ->isNotNull('decon_practices')
      ->execute();
    
    foreach ($results as $row) {
      $data = json_decode($row->decon_practices, TRUE);
      if (!empty($data)) {
        $update_fields = [];
        
        // Migrate practice frequencies
        foreach ($decon_fields as $field => $type) {
          if (!empty($data[$field])) {
            $update_fields['decon_' . $field] = $data[$field];
          }
        }
        
        // Migrate sops year
        if (!empty($data['sops_year_implemented'])) {
          $update_fields['decon_sops_year_implemented'] = (int) $data['sops_year_implemented'];
        }
        
        if (!empty($update_fields)) {
          $database->update('nfr_questionnaire')
            ->fields($update_fields)
            ->condition('uid', $row->uid)
            ->execute();
        }
      }
    }
    
    // Drop the old JSON column
    $schema->dropField('nfr_questionnaire', 'decon_practices');
  }
  
  return t('Added direct decontamination columns and migrated data from JSON.');
}

/**
 * Add direct PPE columns and migrate from JSON.
 */
function nfr_update_9010() {
  $schema = \Drupal::database()->schema();
  $database = \Drupal::database();
  
  $ppe_fields = [
    'scba', 'turnout_coat', 'turnout_pants', 'gloves',
    'helmet', 'boots', 'nomex_hood', 'wildland_clothing',
  ];
  
  // Add ever_used and year_started columns for each equipment type
  foreach ($ppe_fields as $field) {
    $ever_used_col = 'ppe_' . $field . '_ever_used';
    $year_started_col = 'ppe_' . $field . '_year_started';
    
    if (!$schema->fieldExists('nfr_questionnaire', $ever_used_col)) {
      $schema->addField('nfr_questionnaire', $ever_used_col, [
        'type' => 'varchar',
        'length' => 10,
        'not null' => FALSE,
      ]);
    }
    
    if (!$schema->fieldExists('nfr_questionnaire', $year_started_col)) {
      $schema->addField('nfr_questionnaire', $year_started_col, [
        'type' => 'int',
        'not null' => FALSE,
      ]);
    }
  }
  
  // Add SCBA frequency columns
  if (!$schema->fieldExists('nfr_questionnaire', 'ppe_scba_during_suppression')) {
    $schema->addField('nfr_questionnaire', 'ppe_scba_during_suppression', [
      'type' => 'varchar',
      'length' => 20,
      'not null' => FALSE,
    ]);
  }
  
  if (!$schema->fieldExists('nfr_questionnaire', 'ppe_scba_during_overhaul')) {
    $schema->addField('nfr_questionnaire', 'ppe_scba_during_overhaul', [
      'type' => 'varchar',
      'length' => 20,
      'not null' => FALSE,
    ]);
  }
  
  // Migrate data from ppe_practices JSON to new columns
  if ($schema->fieldExists('nfr_questionnaire', 'ppe_practices')) {
    $results = $database->select('nfr_questionnaire', 'q')
      ->fields('q', ['uid', 'ppe_practices'])
      ->condition('ppe_practices', '', '<>')
      ->isNotNull('ppe_practices')
      ->execute();
    
    foreach ($results as $row) {
      $data = json_decode($row->ppe_practices, TRUE);
      if (!empty($data)) {
        $update_fields = [];
        
        // Migrate equipment data
        foreach ($ppe_fields as $field) {
          if (isset($data[$field]['ever_used'])) {
            $update_fields['ppe_' . $field . '_ever_used'] = $data[$field]['ever_used'];
          }
          if (!empty($data[$field]['year_started'])) {
            $update_fields['ppe_' . $field . '_year_started'] = (int) $data[$field]['year_started'];
          }
        }
        
        // Migrate SCBA frequency data
        if (!empty($data['scba_during_suppression'])) {
          $update_fields['ppe_scba_during_suppression'] = $data['scba_during_suppression'];
        }
        if (!empty($data['scba_during_overhaul'])) {
          $update_fields['ppe_scba_during_overhaul'] = $data['scba_during_overhaul'];
        }
        
        if (!empty($update_fields)) {
          $database->update('nfr_questionnaire')
            ->fields($update_fields)
            ->condition('uid', $row->uid)
            ->execute();
        }
      }
    }
    
    // Drop the old JSON column
    $schema->dropField('nfr_questionnaire', 'ppe_practices');
  }
  
  return t('Added direct PPE columns and migrated data from JSON.');
}

/**
 * Create nfr_other_employment table and migrate from JSON.
 */
function nfr_update_9009() {
  $schema = \Drupal::database()->schema();
  $database = \Drupal::database();
  
  // Create nfr_other_employment table
  if (!$schema->tableExists('nfr_other_employment')) {
    $schema->createTable('nfr_other_employment', [
      'fields' => [
        'id' => [
          'type' => 'serial',
          'not null' => TRUE,
        ],
        'uid' => [
          'type' => 'int',
          'not null' => TRUE,
          'description' => 'User ID',
        ],
        'occupation' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => FALSE,
        ],
        'industry' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => FALSE,
        ],
        'start_year' => [
          'type' => 'int',
          'not null' => FALSE,
        ],
        'end_year' => [
          'type' => 'int',
          'not null' => FALSE,
        ],
        'exposures' => [
          'type' => 'text',
          'not null' => FALSE,
          'description' => 'JSON array of exposure types',
        ],
        'exposures_other' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => FALSE,
        ],
        'created' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
        ],
        'updated' => [
          'type' => 'int',
          'not null' => TRUE,
          'default' => 0,
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'uid' => ['uid'],
      ],
    ]);
  }
  
  // Add had_other_jobs column
  if (!$schema->fieldExists('nfr_questionnaire', 'had_other_jobs')) {
    $schema->addField('nfr_questionnaire', 'had_other_jobs', [
      'type' => 'varchar',
      'length' => 10,
      'not null' => FALSE,
    ]);
  }
  
  // Migrate data from other_employment_data JSON to new table
  if ($schema->fieldExists('nfr_questionnaire', 'other_employment_data')) {
    $results = $database->select('nfr_questionnaire', 'q')
      ->fields('q', ['uid', 'other_employment_data'])
      ->condition('other_employment_data', '', '<>')
      ->isNotNull('other_employment_data')
      ->execute();
    
    $time = \Drupal::time()->getRequestTime();
    foreach ($results as $row) {
      $data = json_decode($row->other_employment_data, TRUE);
      if (!empty($data)) {
        // Update had_other_jobs
        if (isset($data['had_other_jobs'])) {
          $database->update('nfr_questionnaire')
            ->fields(['had_other_jobs' => $data['had_other_jobs']])
            ->condition('uid', $row->uid)
            ->execute();
        }
        
        // Migrate jobs to new table
        if (!empty($data['jobs']) && is_array($data['jobs'])) {
          foreach ($data['jobs'] as $job) {
            $database->insert('nfr_other_employment')
              ->fields([
                'uid' => $row->uid,
                'occupation' => $job['occupation'] ?? '',
                'industry' => $job['industry'] ?? '',
                'start_year' => $job['start_year'] ?? NULL,
                'end_year' => $job['end_year'] ?? NULL,
                'exposures' => !empty($job['exposures']) ? json_encode(array_filter($job['exposures'])) : NULL,
                'exposures_other' => $job['exposures_other'] ?? '',
                'created' => $time,
                'updated' => $time,
              ])
              ->execute();
          }
        }
      }
    }
    
    // Drop the old JSON column
    $schema->dropField('nfr_questionnaire', 'other_employment_data');
  }
  
  return t('Created nfr_other_employment table and migrated data from JSON.');
}

