/**
 * Implements hook_schema().
 */
/**
 * Implements hook_schema().
 * 
 * Returns empty array to orphan tables from Drupal's schema management.
 * Tables are created in hook_install() and will persist across uninstall/reinstall.
 * This prevents automatic table deletion during module uninstall.
 */
function nfr_schema() {
  // Return empty schema - all tables are managed manually
  // This prevents Drupal from dropping tables on module uninstall
  return [];
}

/**
 * Create validation test users and assign role permissions.
 */
function nfr_update_9015() {
  // Assign permissions to roles
  _nfr_assign_role_permissions();
  
  // Create validation test users
  _nfr_create_validation_users();
  
  return t('Created validation test users and assigned role permissions.');
}

/**
 * Fix validation user roles - ensure all validation users have correct roles assigned.
 */
function nfr_update_9016() {
  $validation_users = [
    2 => ['username' => 'firefighter_active', 'role' => 'firefighter'],
    3 => ['username' => 'firefighter_retired', 'role' => 'firefighter'],
    4 => ['username' => 'nfr_admin', 'role' => 'nfr_administrator'],
    5 => ['username' => 'nfr_researcher', 'role' => 'nfr_researcher'],
    6 => ['username' => 'dept_admin', 'role' => 'fire_dept_admin'],
  ];
  
  $fixed = 0;
  foreach ($validation_users as $uid => $user_data) {
    $user = \Drupal\user\Entity\User::load($uid);
    if ($user && !$user->hasRole($user_data['role'])) {
      $user->addRole($user_data['role']);
      $user->save();
      $fixed++;
      \Drupal::logger('nfr')->info('Fixed role for user @username (UID: @uid) - added @role', [
        '@username' => $user->getAccountName(),
        '@uid' => $uid,
        '@role' => $user_data['role'],
      ]);
    }
  }
  
  return t('Fixed roles for @count validation users.', ['@count' => $fixed]);
}

/**
 * Recreate validation test users if they don't exist.
 */
function nfr_update_9017() {
  _nfr_create_validation_users();
  return t('Validation test users created/updated.');
}

/**
 * Create NFR custom roles if they don't exist.
 */
function nfr_update_9018() {
  $roles = [
    'firefighter' => [
      'label' => 'Firefighter',
      'weight' => 3,
    ],
    'fire_dept_admin' => [
      'label' => 'Fire Department Administrator',
      'weight' => 4,
    ],
    'nfr_researcher' => [
      'label' => 'NFR Researcher',
      'weight' => 5,
    ],
    'nfr_administrator' => [
      'label' => 'NFR Administrator',
      'weight' => 6,
    ],
  ];
  
  $created = 0;
  foreach ($roles as $role_id => $role_info) {
    $role = \Drupal\user\Entity\Role::load($role_id);
    if (!$role) {
      $role = \Drupal\user\Entity\Role::create([
        'id' => $role_id,
        'label' => $role_info['label'],
        'weight' => $role_info['weight'],
      ]);
      $role->save();
      $created++;
      \Drupal::logger('nfr')->info('Created role: @label (@id)', [
        '@label' => $role_info['label'],
        '@id' => $role_id,
      ]);
    }
  }
  
  // Assign permissions to roles
  _nfr_assign_role_permissions();
  
  return t('Created @count NFR roles and assigned permissions.', ['@count' => $created]);
}

/**
 * Recreate validation test users after roles are created.
 */
function nfr_update_9019() {
  _nfr_create_validation_users();
  return t('Validation test users created/updated.');
}

/**
 * Update validation users to follow test naming patterns.
 */
function nfr_update_9020() {
  $old_usernames = [
    'firefighter_active',
    'firefighter_retired', 
    'nfr_admin',
    'nfr_researcher',
    'dept_admin',
    'firefighter',
    'fire_department_admin',
  ];
  
  $deleted = 0;
  
  // Delete old validation users
  foreach ($old_usernames as $username) {
    $users = \Drupal::entityTypeManager()
      ->getStorage('user')
      ->loadByProperties(['name' => $username]);
    
    if (!empty($users)) {
      foreach ($users as $user) {
        if ($user->id() > 1) { // Never delete admin
          $user->delete();
          $deleted++;
          \Drupal::logger('nfr')->info('Deleted old validation user: @username', ['@username' => $username]);
        }
      }
    }
  }
  
  // Create new validation users with test naming pattern
  _nfr_create_validation_users();
  
  return t('Deleted @count old validation users and created new test-pattern users.', ['@count' => $deleted]);
}

