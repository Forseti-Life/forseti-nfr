      'template' => 'nfr-documentation',
    ],
    'nfr_documentation_page' => [
      'variables' => [
        'title' => NULL,
        'content' => NULL,
        'file_info' => [],
      ],
      'template' => 'nfr-documentation-page',
    ],    'nfr_public_page' => [
      'variables' => [
        'page_id' => '',
        'content' => [],
      ],
      'template' => 'nfr-public-page',
    ],
    'nfr_home_page' => [
